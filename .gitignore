node_modules/
dist/
build/
coverage/
*.tsbuildinfo
*.tgz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local logs / temp
*.log
*.tmp
*.temp
.cache/
.tmp/
tmp/
